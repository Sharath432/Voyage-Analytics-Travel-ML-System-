from airflow import DAG
from airflow.operators.bash import BashOperator
from datetime import datetime

default_args = {
    "owner": "SarathRaj",
    "depends_on_past": False
}

with DAG(
    dag_id="flight_price_ml_pipeline",
    default_args=default_args,
    start_date=datetime(2024, 1, 1),
    schedule="@daily",
    catchup=False,
    tags=["flight", "mlops"],
) as dag:

    install_dependencies = BashOperator(
        task_id="install_dependencies",
        bash_command="pip install -r requirements.txt"
    )

    mlflow_tracking = BashOperator(
        task_id="run_mlflow_tracking",
        bash_command="python mlflow_tracking.py"
    )

    start_streamlit = BashOperator(
        task_id="start_streamlit",
        bash_command="streamlit run app.py"
    )

    install_dependencies >> mlflow_tracking >> start_streamlit